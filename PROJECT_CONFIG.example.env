# Safe example configuration for Sip Mind.
# Copy this file to PROJECT_CONFIG.env or .env for local private values.
# Do not commit private files containing real secrets.

PROJECT_NAME=sip_mind
NODE_ENV=production
HOST=127.0.0.1
PORT=8787
PUBLIC_APP_URL=https://sipmind.xyz
CORS_ORIGIN=https://sipmind.xyz
JSON_BODY_LIMIT=64kb

GITHUB_REPO_URL=https://github.com/nickxu1996/sip_mind.git
GITHUB_BRANCH=master

VULTR_HOST=your-vultr-host
VULTR_USER=root
VULTR_PROJECT_PATH=/opt/sip_mind
SYSTEMD_SERVICE_NAME=sip-mind

DEFAULT_INTERNAL_LANGUAGE=en
SUPPORTED_UI_LANGUAGES=en,zh
DEFAULT_UI_LANGUAGE=en

AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=replace-with-private-value
DEEPSEEK_API_KEY=replace-with-private-value

CONTACT_TO_EMAIL=nickxu1996@gmail.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-private-value
SMTP_PASS=replace-with-private-value
SMTP_FROM=replace-with-private-value
